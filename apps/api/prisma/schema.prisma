// JARVIS database schema.
// Milestone 1: foundation tables only.
// pgvector-backed tables (memories, document_chunks) arrive in Milestone 2.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // native = local dev (Windows). debian target = the Render Docker image.
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  email             String?  @unique
  // Supabase auth user id (JWT `sub`) — set in cloud mode.
  authId            String?  @unique @map("auth_id")
  preferredLanguage String   @default("es") @map("preferred_language")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  projects         Project[]
  conversations    Conversation[]
  messages         Message[]
  providerSettings ProviderSetting[]
  memories         Memory[]
  subscription     Subscription?
  aiSetting        AiSetting?
  payments         Payment[]
  documents        Document[]
  documentChunks   DocumentChunk[]
  ingestionJobs    IngestionJob[]
  actionLogs       ActionLog[]

  @@map("users")
}

model AiSetting {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  // auto | anthropic | openai
  preferredProvider String   @default("auto") @map("preferred_provider")
  model             String?
  // BYO keys, encrypted at rest (AES-GCM). Never returned to the client.
  anthropicKeyEnc   String?  @map("anthropic_key_enc")
  openaiKeyEnc      String?  @map("openai_key_enc")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

model UsageLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  provider      String
  model         String
  taskType      String?  @map("task_type")
  inputTokens   Int      @default(0) @map("input_tokens")
  outputTokens  Int      @default(0) @map("output_tokens")
  estimatedCost Float    @default(0) @map("estimated_cost") // USD
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("usage_logs")
}

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique // free | pro
  name        String
  description String?
  features    String[] // feature flags unlocked by this plan
  limits      Json // { messagesPerMonth, memories, storageMb, ... }
  priceArs    Int      @default(0) @map("price_ars") // monthly price in ARS (Milestone 4)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  planId           String    @map("plan_id") @db.Uuid
  status           String    @default("active") // active | trialing | past_due | canceled
  currentPeriodEnd DateTime? @map("current_period_end")
  mpPreapprovalId  String?   @map("mp_preapproval_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Payment {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  provider   String   @default("mercadopago")
  // Mercado Pago id (preapproval id or payment id).
  externalId String?  @map("external_id")
  // preapproval | payment
  kind       String
  status     String
  amount     Int? // in the currency's minor-less unit (ARS whole pesos)
  currency   String?
  raw        Json? // raw provider payload for auditing
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([externalId])
  @@map("payments")
}

// Knowledge source document (Obsidian import / uploaded file). See
// docs/MEMORY_ARCHITECTURE.md + docs/OBSIDIAN_INTEGRATION.md.
model Document {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid
  source      String // 'obsidian' | 'upload'
  title       String
  path        String // original path within the vault, e.g. "Folder/Sub/note.md"
  mime        String   @default("text/markdown")
  tags        String[]
  bytes       Int      @default(0)
  // sha256 of the raw content → idempotent re-imports (skip when unchanged).
  contentHash String?  @map("content_hash")
  status      String   @default("pending") // pending | indexing | indexed | error
  chunkCount  Int      @default(0) @map("chunk_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]

  // Logical identity: userId + source + projectId + path (handled in code; same
  // path can exist under different projects). Index for fast lookup.
  @@index([userId, source, path])
  @@index([userId])
  @@map("documents")
}

model DocumentChunk {
  id         String  @id @default(uuid()) @db.Uuid
  documentId String  @map("document_id") @db.Uuid
  userId     String  @map("user_id") @db.Uuid
  projectId  String? @map("project_id") @db.Uuid
  source     String
  path       String
  heading    String?
  tags       String[]
  ord        Int     @default(0)
  content    String
  // 768-dim embedding (managed via raw SQL, like memories).
  embedding  Unsupported("vector(768)")?
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
  @@map("document_chunks")
}

// Import/indexing job (synchronous today; ready to move to BullMQ/Redis later).
model IngestionJob {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  projectId      String?   @map("project_id") @db.Uuid
  source         String
  status         String    @default("pending") // pending | processing | completed | failed
  totalFiles     Int       @default(0) @map("total_files")
  processedFiles Int       @default(0) @map("processed_files")
  failedFiles    Int       @default(0) @map("failed_files")
  error          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ingestion_jobs")
}

// Basic audit of what the orchestrator did per request.
model ActionLog {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  taskType         String   @map("task_type")
  provider         String?
  model            String?
  knowledgeSources Int      @default(0) @map("knowledge_sources")
  toolsUsed        String[] @map("tools_used")
  estimatedCost    Float    @default(0) @map("estimated_cost")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("action_logs")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  memories      Memory[]

  @@unique([userId, name])
  @@map("projects")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([userId])
  @@index([projectId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           String // "user" | "assistant" | "system"
  content        String
  // Metadata about how the message was produced (provider, model, tokens, etc.)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Provider {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  type      String // llm | embedding | speech_to_text | text_to_speech | automation | vector_db | notification
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  settings ProviderSetting[]

  @@map("providers")
}

model ProviderSetting {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  providerId   String   @map("provider_id") @db.Uuid
  settingKey   String   @map("setting_key")
  // Non-secret config values only. Secrets live behind secretRef (env var name).
  settingValue String?  @map("setting_value")
  secretRef    String?  @map("secret_ref")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId, settingKey])
  @@map("provider_settings")
}

model Memory {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @map("user_id") @db.Uuid
  projectId              String?  @map("project_id") @db.Uuid
  // session | profile | preference | project | decision | document | obsidian | procedure | action_log | task
  type                   String
  content                String
  source                 String?
  confidence             Float    @default(1.0)
  tags                   String[]
  visibility             String   @default("private")
  canBeUsedAutomatically Boolean  @default(true) @map("can_be_used_automatically")
  // 768-dim embedding (nomic-embed-text). Managed via raw SQL (see MemoryService).
  embedding              Unsupported("vector(768)")?
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([type])
  @@map("memories")
}
