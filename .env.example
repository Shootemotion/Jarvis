# ============================================================
# JARVIS - Example environment file
# Copy to `.env` and adjust. Never commit `.env`.
# ============================================================

# --- App ---
APP_ENV=local
# selfhost = local single-user (no login). cloud = hosted SaaS (Supabase auth required).
DEPLOYMENT_MODE=selfhost
API_PORT=4010
WEB_PORT=3000
# URL the web app uses to reach the API (browser side)
NEXT_PUBLIC_API_URL=http://localhost:4010
# Production only: comma-separated browser origins allowed by CORS
# (e.g. https://jarvis.vercel.app). Unset = localhost + PUBLIC_WEB_URL.
CORS_ORIGINS=

# --- Supabase (only needed for DEPLOYMENT_MODE=cloud) ---
# From your Supabase project → Settings → API
SUPABASE_URL=
SUPABASE_JWT_SECRET=
# Public values for the web app (browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Single-user (MVP has no auth) ---
JARVIS_USER_NAME=Bruno
JARVIS_USER_EMAIL=bruno.cleri@diagnos.com.ar

# --- Database (matches docker/docker-compose.yml) ---
DATABASE_URL=postgresql://jarvis:jarvis@localhost:5432/jarvis?schema=public

# --- Local AI (Ollama runs natively on Windows, not in Docker) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:3b

# --- Embeddings ---
# local  = Ollama / nomic-embed-text (self-host).
# openai = text-embedding-3-small truncated to EMBEDDING_DIMENSIONS (cloud, no Ollama).
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=nomic-embed-text
# Vector dimensions (must match the pgvector column). nomic-embed-text = 768;
# for EMBEDDING_PROVIDER=openai keep 768 so the schema stays unchanged.
EMBEDDING_DIMENSIONS=768

# --- Optional paid AI providers (leave blank until Milestone 4) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# --- Obsidian ---
OBSIDIAN_ENABLED=true
OBSIDIAN_VAULT_PATH=C:\Users\Bruno\Documents\Obsidian\JarvisVault

# --- Telegram (Milestone 4+) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Billing: Mercado Pago (cloud mode) ---
# From mercadopago.com.ar/developers → tu aplicación → Credenciales.
# Sin MP_ACCESS_TOKEN el billing corre en modo DEV (checkout simulado).
MP_ACCESS_TOKEN=
# Clave secreta de la firma de webhooks (Notificaciones/Webhooks en el panel).
MP_WEBHOOK_SECRET=
# URL pública del frontend (para las back_url de Mercado Pago).
PUBLIC_WEB_URL=http://localhost:3000
# Precio y prueba del plan Pro (ARS). Sobrescriben el placeholder de plans.ts.
PRO_PRICE_ARS=4999
PRO_TRIAL_DAYS=0

# --- n8n ---
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# --- Security ---
REQUIRE_CONFIRMATION_FOR_SENSITIVE_ACTIONS=true

# --- Budget (tracked now, hard-stop enforced in Milestone 4+) ---
DAILY_API_BUDGET_USD=2
MONTHLY_API_BUDGET_USD=30
BUDGET_WARNING_PERCENT=70

# Encryption key for BYO API keys at rest (32 bytes, hex or base64)
JARVIS_ENCRYPTION_KEY=
