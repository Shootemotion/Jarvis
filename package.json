{
  "name": "jarvis",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @jarvis/api db:migrate",
    "db:seed": "pnpm --filter @jarvis/api db:seed",
    "db:reset": "pnpm --filter @jarvis/api db:reset"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
